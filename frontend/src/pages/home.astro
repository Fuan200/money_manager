---
import { HomeDashboard } from '../components/HomeDashboard';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Money Manager | Home">
	<main class="home-page">
		<HomeDashboard client:load />
	</main>
</Layout>

<style>
	:global(body) {
		min-height: 100vh;
		background:
			radial-gradient(circle at top left, rgba(var(--color-pearl-aqua-rgb), 0.14), transparent 28%),
			linear-gradient(145deg, var(--color-bg) 0%, var(--color-surface) 48%, var(--color-bg) 100%);
	}

	.home-page {
		min-height: 100vh;
		padding: clamp(1.25rem, 3vw, 3rem);
		box-sizing: border-box;
	}

	:global(.home-shell) {
		display: grid;
		gap: 1.25rem;
		max-width: 72rem;
		margin: 0 auto;
	}

	:global(.summary-card),
	:global(.info-card) {
		border: 1px solid rgba(var(--color-pearl-aqua-rgb), 0.12);
		border-radius: var(--radius-lg);
		background: var(--color-surface-strong);
		box-shadow: var(--shadow-soft);
		backdrop-filter: blur(14px);
	}

	:global(.summary-card) {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: clamp(1.4rem, 3vw, 2.25rem);
	}

	:global(.panel-grid) {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	:global(.info-card) {
		padding: 1.5rem;
	}

	:global(.panel-label) {
		margin: 0 0 0.8rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	:global(.summary-card h1),
	:global(.info-card h2) {
		margin: 0;
		letter-spacing: -0.04em;
	}

	:global(.summary-card h1) {
		font-size: clamp(2rem, 4vw, 3.25rem);
	}

	:global(.info-card h2) {
		font-size: 1.35rem;
	}

	:global(.panel-copy) {
		margin: 0.9rem 0 0;
		color: rgba(var(--color-snow-rgb), 0.7);
		font-size: 0.98rem;
		line-height: 1.7;
	}

	:global(.ghost-button) {
		padding: 0.9rem 1.1rem;
		border: 1px solid rgba(var(--color-pearl-aqua-rgb), 0.2);
		border-radius: var(--radius-pill);
		background: rgba(var(--color-onyx-rgb), 0.7);
		color: var(--color-text);
		font: inherit;
		font-weight: 700;
		transition:
			background-color var(--transition-standard),
			color var(--transition-standard),
			transform var(--transition-standard);
	}

	:global(.ghost-button:hover),
	:global(.ghost-button:focus-visible) {
		background: var(--color-accent);
		color: var(--color-bg);
		transform: translateY(-1px);
	}

	:global(.ghost-button:focus-visible) {
		outline: 0.2rem solid var(--color-focus-ring);
		outline-offset: 0.15rem;
	}

	@media (max-width: 900px) {
		:global(.panel-grid) {
			grid-template-columns: 1fr;
		}

		:global(.summary-card) {
			flex-direction: column;
		}
	}
</style>
