---
import { LoginForm } from '../components/LoginForm';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Money Manager | Login">
	<main class="login-page">
		<LoginForm client:load />
	</main>
</Layout>

<style>
	:global(body) {
		min-height: 100vh;
		background:
			radial-gradient(circle at top left, rgba(125, 226, 209, 0.18), transparent 30%),
			radial-gradient(circle at bottom right, rgba(51, 153, 137, 0.16), transparent 28%),
			linear-gradient(135deg, #131515 0%, #2b2c28 55%, #131515 100%);
		color: #fffafb;
	}

	:global(.login-card) {
		position: relative;
		z-index: 1;
		width: min(100%, 28rem);
		padding: 2rem;
		border: 1px solid rgba(125, 226, 209, 0.16);
		border-radius: 1.75rem;
		background:
			linear-gradient(180deg, rgba(43, 44, 40, 0.96), rgba(19, 21, 21, 0.94)) padding-box,
			linear-gradient(180deg, rgba(125, 226, 209, 0.3), rgba(51, 153, 137, 0.16)) border-box;
		box-shadow:
			0 1.5rem 4rem rgba(0, 0, 0, 0.34),
			inset 0 1px 0 rgba(255, 250, 251, 0.04);
		backdrop-filter: blur(16px);
	}

	:global(.card-header) {
		margin-bottom: 1.75rem;
	}

	:global(.eyebrow) {
		margin: 0 0 0.75rem;
		color: #339989;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	:global(.login-card h1) {
		margin: 0;
		color: #fffafb;
		font-size: clamp(2rem, 3vw, 2.6rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	:global(.card-copy) {
		margin: 1rem 0 0;
		color: rgba(255, 250, 251, 0.72);
		font-size: 0.98rem;
		line-height: 1.7;
	}

	:global(.login-form) {
		display: grid;
		gap: 1rem;
	}

	:global(.field) {
		display: grid;
		gap: 0.6rem;
		color: #fffafb;
		font-size: 0.95rem;
		font-weight: 600;
	}

	:global(.field-label-row) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	:global(.login-form input) {
		width: 100%;
		padding: 0.95rem 1rem;
		border: 1px solid rgba(125, 226, 209, 0.14);
		border-radius: 0.95rem;
		background: rgba(19, 21, 21, 0.72);
		color: #fffafb;
		font: inherit;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	:global(.login-form input::placeholder) {
		color: rgba(255, 250, 251, 0.38);
	}

	:global(.login-form input:focus) {
		outline: none;
		border-color: rgba(125, 226, 209, 0.62);
		box-shadow: 0 0 0 0.25rem rgba(125, 226, 209, 0.14);
		transform: translateY(-1px);
	}

	:global(.submit-button) {
		margin-top: 0.25rem;
		padding: 1rem 1.25rem;
		border: none;
		border-radius: 999px;
		background: #339989;
		color: #131515;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease,
			opacity 0.2s ease;
	}

	:global(.submit-button:hover),
	:global(.submit-button:focus-visible) {
		background: #7de2d1;
		box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.28);
		transform: translateY(-1px);
	}

	:global(.submit-button:focus-visible) {
		outline: 0.2rem solid rgba(125, 226, 209, 0.55);
		outline-offset: 0.15rem;
	}

	:global(.submit-button:disabled) {
		opacity: 0.7;
		cursor: wait;
	}

	:global(.error-banner) {
		margin: 0;
		padding: 0.85rem 1rem;
		border: 1px solid rgba(125, 226, 209, 0.16);
		border-radius: 0.95rem;
		background: rgba(51, 153, 137, 0.14);
		color: #fffafb;
		font-size: 0.93rem;
		line-height: 1.5;
	}

	:global(.card-footer) {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.5rem;
		color: rgba(255, 250, 251, 0.62);
		font-size: 0.95rem;
	}

	:global(.card-footer p) {
		margin: 0;
	}

	:global(.secondary-link) {
		color: #339989;
		text-decoration: none;
	}

	:global(.secondary-link:hover),
	:global(.secondary-link:focus-visible) {
		color: #7de2d1;
	}

	:global(.secondary-link:focus-visible) {
		outline: 0.15rem solid rgba(125, 226, 209, 0.55);
		outline-offset: 0.15rem;
		border-radius: 0.35rem;
	}

	.login-page {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
		justify-items: center;
		min-height: 100vh;
		padding: clamp(1.5rem, 4vw, 4rem);
		box-sizing: border-box;
		overflow: hidden;
	}

	.login-page::before,
	.login-page::after {
		content: '';
		position: absolute;
		border-radius: 999px;
		pointer-events: none;
		filter: blur(8px);
	}

	.login-page::before {
		top: 10%;
		right: 18%;
		width: 14rem;
		height: 14rem;
		background: rgba(125, 226, 209, 0.12);
	}

	.login-page::after {
		bottom: 8%;
		left: 8%;
		width: 18rem;
		height: 18rem;
		background: rgba(51, 153, 137, 0.14);
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 40rem;
	}

	.hero-eyebrow {
		margin: 0 0 1rem;
		color: #339989;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		font-size: clamp(2.8rem, 6vw, 5.75rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
		max-width: 10ch;
	}

	.hero-text {
		max-width: 34rem;
		margin: 1.5rem 0 0;
		color: rgba(255, 250, 251, 0.72);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.hero-metrics {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
		max-width: 32rem;
	}

	.metric-card {
		padding: 1.15rem 1.2rem;
		border: 1px solid rgba(125, 226, 209, 0.12);
		border-radius: 1.25rem;
		background: rgba(43, 44, 40, 0.6);
		backdrop-filter: blur(14px);
	}

	.metric-value {
		display: block;
		margin-bottom: 0.45rem;
		color: #fffafb;
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.metric-label {
		color: rgba(255, 250, 251, 0.64);
		font-size: 0.94rem;
		line-height: 1.5;
	}

	@media (max-width: 960px) {
		.login-page {
			grid-template-columns: 1fr;
			align-items: start;
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.hero-copy {
			max-width: none;
		}

		h2 {
			max-width: 12ch;
		}
	}

	@media (max-width: 640px) {
		.login-page {
			gap: 1.5rem;
			padding: 1.25rem;
		}

		h2 {
			font-size: clamp(2.4rem, 14vw, 3.6rem);
			max-width: none;
		}

		.hero-text {
			font-size: 0.98rem;
		}

		.hero-metrics {
			grid-template-columns: 1fr;
		}

		:global(.login-card) {
			padding: 1.5rem;
			border-radius: 1.4rem;
		}

		:global(.field-label-row),
		:global(.card-footer) {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
