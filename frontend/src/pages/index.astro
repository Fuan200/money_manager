---
import { LoginForm } from '../components/LoginForm';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Money Manager | Login">
	<main class="login-page">
		<LoginForm client:load />
	</main>
</Layout>

<style>
	:global(body) {
		/* background:
			radial-gradient(circle at top left, rgba(var(--color-pearl-aqua-rgb), 0.18), transparent 30%),
			radial-gradient(circle at bottom right, rgba(var(--color-verdigris-rgb), 0.16), transparent 28%),
			linear-gradient(135deg, var(--color-bg) 0%, var(--color-surface) 55%, var(--color-bg) 100%); */
	}

	:global(.login-card) {
		position: relative;
		z-index: 1;
		width: min(100%, 28rem);
		padding: 2rem;
		border: 3px solid var(--color-graphite);
		border-radius: var(--radius-xl);
		/* background:
			linear-gradient(180deg, rgba(var(--color-graphite-rgb), 0.96), rgba(var(--color-onyx-rgb), 0.94))
				padding-box,
			linear-gradient(180deg, var(--color-border-strong), var(--color-accent-wash)) border-box;
		box-shadow:
			var(--shadow-elevated),
			inset 0 1px 0 rgba(var(--color-snow-rgb), 0.04); */
		backdrop-filter: blur(16px);
	}

	:global(.card-header) {
		margin-bottom: 1.75rem;
	}

	:global(.eyebrow) {
		margin: 0 0 0.75rem;
		color: var(--color-accent);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	:global(.login-card h1) {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 3vw, 2.6rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	:global(.card-copy) {
		margin: 1rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.98rem;
		line-height: 1.7;
	}

	:global(.login-form) {
		display: grid;
		gap: 1rem;
	}

	:global(.auth-toggle) {
		display: inline-grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.35rem;
		width: 100%;
		margin-bottom: 1.25rem;
		padding: 0.35rem;
		border: 1px solid rgba(var(--color-pearl-aqua-rgb), 0.12);
		border-radius: var(--radius-pill);
		background: rgba(var(--color-onyx-rgb), 0.55);
	}

	:global(.auth-toggle-button) {
		padding: 0.8rem 1rem;
		border-radius: var(--radius-pill);
		background: transparent;
		color: var(--color-text-muted);
		font: inherit;
		font-weight: 700;
		line-height: 1;
		transition:
			background-color var(--transition-standard),
			color var(--transition-standard),
			transform var(--transition-standard);
	}

	:global(.auth-toggle-button:hover),
	:global(.auth-toggle-button:focus-visible) {
		color: var(--color-text);
		transform: translateY(-1px);
	}

	:global(.auth-toggle-button.is-active) {
		background: var(--color-accent);
		color: var(--color-bg);
		box-shadow: 0 0.6rem 1.2rem rgba(var(--color-onyx-rgb), 0.24);
	}

	:global(.field) {
		display: grid;
		gap: 0.6rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 600;
	}

	:global(.field-label-row) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	:global(.login-form input) {
		width: 100%;
		padding: 0.95rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-surface-muted);
		color: var(--color-text);
		font: inherit;
		transition:
			border-color var(--transition-standard),
			box-shadow var(--transition-standard),
			transform var(--transition-standard);
	}

	:global(.login-form input::placeholder) {
		color: rgba(var(--color-snow-rgb), 0.38);
	}

	:global(.login-form input:focus) {
		outline: none;
		border-color: rgba(var(--color-pearl-aqua-rgb), 0.62);
		box-shadow: 0 0 0 0.25rem var(--color-accent-soft);
		transform: translateY(-1px);
	}

	:global(.submit-button) {
		margin-top: 1rem;
		padding: 1rem 1.25rem;
		border: none;
		border-radius: var(--radius-pill);
		background: var(--color-accent);
		color: var(--color-bg);
		font: inherit;
		font-weight: 700;
		transition:
			transform var(--transition-standard),
			box-shadow var(--transition-standard),
			background-color var(--transition-standard),
			opacity var(--transition-standard);
	}

	:global(.submit-button:hover),
	:global(.submit-button:focus-visible) {
		background: var(--color-accent-strong);
		box-shadow: 0 1rem 2rem var(--color-shadow);
		transform: translateY(-1px);
	}

	:global(.submit-button:focus-visible) {
		outline: 0.2rem solid var(--color-focus-ring);
		outline-offset: 0.15rem;
	}

	:global(.submit-button:disabled) {
		opacity: 0.7;
		cursor: wait;
	}

	:global(.error-banner) {
		margin: 0;
		padding: 0.85rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-accent-wash);
		color: var(--color-text);
		font-size: 0.93rem;
		line-height: 1.5;
	}

	:global(.card-footer) {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.5rem;
		color: var(--color-text-soft);
		font-size: 0.95rem;
	}

	:global(.card-footer p) {
		margin: 0;
	}

	:global(.secondary-link) {
		color: var(--color-accent);
		text-decoration: none;
	}

	:global(.secondary-link:hover),
	:global(.secondary-link:focus-visible) {
		color: var(--color-accent-strong);
	}

	:global(.secondary-link:focus-visible) {
		outline: 0.15rem solid var(--color-focus-ring);
		outline-offset: 0.15rem;
		border-radius: 0.35rem;
	}

	.login-page {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
		justify-items: center;
		min-height: 100vh;
		padding: clamp(1.5rem, 4vw, 4rem);
		box-sizing: border-box;
		overflow: hidden;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 40rem;
	}

	.hero-eyebrow {
		margin: 0 0 1rem;
		color: var(--color-accent);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		font-size: clamp(2.8rem, 6vw, 5.75rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
		max-width: 10ch;
	}

	.hero-text {
		max-width: 34rem;
		margin: 1.5rem 0 0;
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.hero-metrics {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
		max-width: 32rem;
	}

	.metric-card {
		padding: 1.15rem 1.2rem;
		border: 1px solid rgba(var(--color-pearl-aqua-rgb), 0.12);
		border-radius: var(--radius-md);
		background: rgba(var(--color-graphite-rgb), 0.6);
		backdrop-filter: blur(14px);
	}

	.metric-value {
		display: block;
		margin-bottom: 0.45rem;
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.metric-label {
		color: rgba(var(--color-snow-rgb), 0.64);
		font-size: 0.94rem;
		line-height: 1.5;
	}

	@media (max-width: 960px) {
		.login-page {
			grid-template-columns: 1fr;
			align-items: start;
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.hero-copy {
			max-width: none;
		}

		h2 {
			max-width: 12ch;
		}
	}

	@media (max-width: 640px) {
		.login-page {
			gap: 1.5rem;
			padding: 1.25rem;
		}

		h2 {
			font-size: clamp(2.4rem, 14vw, 3.6rem);
			max-width: none;
		}

		.hero-text {
			font-size: 0.98rem;
		}

		.hero-metrics {
			grid-template-columns: 1fr;
		}

		:global(.login-card) {
			padding: 1.5rem;
			border-radius: 1.4rem;
		}

		:global(.field-label-row),
		:global(.card-footer) {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
