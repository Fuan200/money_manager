---
interface Props {
	title?: string;
}

const { title = 'Money Manager' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:global(:root) {
		color-scheme: dark;
		font-family:
			'Segoe UI', 'Aptos', 'Helvetica Neue', Arial, sans-serif;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(a),
	:global(button),
	:global(input) {
		-webkit-tap-highlight-color: transparent;
	}
</style>
